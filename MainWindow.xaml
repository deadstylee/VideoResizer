<Window x:Class="VideoResizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1100"
        Height="650"
        Background="#0A0A0A"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>

        <Style x:Key="GlowButton" TargetType="Button">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="42"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1B1B1B"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="25"
                                                          ShadowDepth="0"
                                                          Color="White"
                                                          Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="#1A1A1A"
                                CornerRadius="6"
                                ClipToBounds="True">

                            <Grid>

                                <Border x:Name="PART_Indicator"
                                        Background="#E6E6E6"
                                        HorizontalAlignment="Left"
                                        CornerRadius="6"/>

                                <Rectangle IsHitTestVisible="False"
                                           Opacity="0.25">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00000000" Offset="0"/>
                                            <GradientStop Color="#80FFFFFF" Offset="0.5"/>
                                            <GradientStop Color="#00000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>

                                    <Rectangle.RenderTransform>
                                        <TranslateTransform x:Name="ShimmerTransform"/>
                                    </Rectangle.RenderTransform>

                                    <Rectangle.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ShimmerTransform"
                                                        Storyboard.TargetProperty="X"
                                                        From="-300"
                                                        To="500"
                                                        Duration="0:0:1.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Rectangle.Triggers>
                                </Rectangle>

                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid AllowDrop="True"
          Drop="Window_Drop"
          DragOver="Window_DragOver">

        <Grid Height="49" VerticalAlignment="Top" Background="#0F0F0F">

            <Image Source="logo.png"
                   Height="258"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top" Margin="360,-106,0,0"/>

            <Button Content="✕"
                    Width="42"
                    Height="42"
                    HorizontalAlignment="Right"
                    Margin="0,6,10,0"
                    Background="Transparent"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Close_Click"/>
        </Grid>

        <Grid Margin="20,80,20,20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <Border Height="220"
                        Background="#121212"
                        CornerRadius="16"
                        MouseLeftButtonDown="DropArea_Click"/>


                <Button Content="SET RESOLUTION"
                        Margin="0,12,0,0"
                        Style="{StaticResource GlowButton}"
                        Click="OpenResolution"/>

                <Button Content="START"
                        Margin="0,10,0,0"
                        Style="{StaticResource GlowButton}"
                        Click="StartQueue"/>

            </StackPanel>

            <Grid Grid.Column="1" Margin="20,0,0,0">

                <StackPanel>

                    <Border Height="260"
                            Background="#121212"
                            CornerRadius="16"
                            ClipToBounds="True">

                        <MediaElement x:Name="ResultPreview"
              LoadedBehavior="Manual"
              UnloadedBehavior="Manual"
              Stretch="Fill"/>

                    </Border>

                    <Button Content="QUEUE"
                            Margin="0,10,0,0"
                            Style="{StaticResource GlowButton}"
                            Click="ToggleQueue"/>

                    <ListBox x:Name="QueueItems"
         Background="Transparent"
         Foreground="White"
         BorderThickness="0"
         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
         ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                    <ProgressBar x:Name="Progress"
                                 Margin="0,10,0,0"
                                 Minimum="0"
                                 Maximum="100"/>

                    <Button Content="CANCEL"
                            Margin="0,10,0,0"
                            Style="{StaticResource GlowButton}"
                            Click="Cancel"/>

                </StackPanel>

            </Grid>

        </Grid>

        <Grid x:Name="ResolutionOverlay"
              Visibility="Collapsed"
              Background="#AA000000">

            <Border Width="340"
                    Height="220"
                    Background="#141414"
                    CornerRadius="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel Margin="20">

                    <TextBox x:Name="WidthInput"
                             Text="1920"
                             Style="{StaticResource GlassTextBox}"/>

                    <TextBox x:Name="HeightInput"
                             Text="1080"
                             Margin="0,10,0,0"
                             Style="{StaticResource GlassTextBox}"/>

                    <Button Content="APPLY"
                            Margin="0,12,0,0"
                            Style="{StaticResource GlowButton}"
                            Click="ApplyResolution"/>
                </StackPanel>

            </Border>
        </Grid>

        <Canvas x:Name="ToastHost"
                IsHitTestVisible="False"/>

    </Grid>
</Window>